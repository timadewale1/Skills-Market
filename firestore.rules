rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isGigClient(gigId) {
      return signedIn() && firestore.exists(/databases/$(database)/documents/gigs/$(gigId))
        && request.auth.uid == firestore.get(/databases/$(database)/documents/gigs/$(gigId)).data.clientUid;
    }

    function kycStatusAllowed(oldStatus, newStatus) {
      return newStatus == oldStatus || newStatus == "pending";
    }

    function orgKycStatusAllowed(oldStatus, newStatus) {
      return newStatus == oldStatus || newStatus == "pending";
    }

    // ===== USERS =====
    match /users/{uid} {
      allow read: if isMe(uid) || isAdmin();

      allow write: if isAdmin()
        || (
          isMe(uid)
          && (
            !("kyc" in request.resource.data)
            || (
              kycStatusAllowed(resource.data.kyc.status, request.resource.data.kyc.status)
              && !("adminNotes" in request.resource.data.kyc)
            )
          )
          && (
            !("orgKyc" in request.resource.data)
            || (
              orgKycStatusAllowed(resource.data.orgKyc.status, request.resource.data.orgKyc.status)
              && !("adminNotes" in request.resource.data.orgKyc)
            )
          )
        );

      match /gigs/{gigId} {
        allow read, write: if isMe(uid) || isAdmin();
      }

      match /savedGigs/{gigId} {
        allow read, write: if isMe(uid);
      }

      match /savedTalents/{talentId} {
        allow read, write: if isMe(uid);
      }

      match /proposals/{gigId} {
        allow read, write: if isMe(uid) || isGigClient(gigId);
      }
    }

    // ===== PUBLIC PROFILES =====
    match /publicProfiles/{uid} {
      allow read: if true;
      allow create, update: if isMe(uid);
      allow delete: if false;
    }

    // ===== GIGS =====
    match /gigs/{gigId} {
      allow read: if isAdmin() || signedIn() || resource.data.status == "open";

      allow create: if signedIn()
        && request.resource.data.clientUid == request.auth.uid;

      allow update, delete: if isAdmin() || (
        signedIn()
        && resource.data.clientUid == request.auth.uid
      );

      match /proposals/{proposalId} {
        allow create: if signedIn()
          && request.resource.data.talentUid == request.auth.uid;

        allow read: if signedIn();

        allow update: if signedIn()
          && (
            get(/databases/$(database)/documents/gigs/$(gigId)).data.clientUid == request.auth.uid
            || (
              resource.data.talentUid == request.auth.uid
              && (
                // Allow edits before client views
                resource.data.viewedAt == null
                ||
                // Allow threadId-only update when proposal accepted and no chat yet
                (
                  resource.data.status == "accepted"
                  && resource.data.threadId == null
                  && request.resource.data.threadId != null
                )
              )
            )
          );

        allow delete: if false;
      }
    }

    // ===== THREADS =====
    match /threads/{threadId} {
      function isThreadParticipant() {
        return signedIn()
          && (request.auth.uid in resource.data.participants);
      }

      allow read: if isAdmin() || isThreadParticipant();

      allow create: if signedIn()
        && request.resource.data.type == "thread"
        && request.resource.data.schemaVersion == 1
        && request.resource.data.threadId is string
        && request.resource.data.gigId is string
        && request.resource.data.gigTitle is string
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.clientUid in request.resource.data.participants
        && request.resource.data.talentUid in request.resource.data.participants
        && request.resource.data.createdAt != null
        && request.resource.data.updatedAt != null;

      allow update: if isThreadParticipant()
        && request.resource.data.threadId == resource.data.threadId
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.updatedAt != null;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || (
          signedIn()
          && (
            request.auth.uid in
            get(/databases/$(database)/documents/threads/$(threadId)).data.participants
          )
        );

        allow create: if signedIn()
          && (
            request.auth.uid in
            get(/databases/$(database)/documents/threads/$(threadId)).data.participants
          )
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.createdAt != null;

        allow update, delete: if false;
      }

      // ===== AGREEMENT =====
      match /agreement/{agreementId} {
        function threadData() {
          return get(/databases/$(database)/documents/threads/$(threadId)).data;
        }

        function isAgreementParticipant() {
          return signedIn()
            && (request.auth.uid in threadData().participants);
        }

        function isClient() {
          return signedIn()
            && request.auth.uid == threadData().clientUid;
        }

        function isTalent() {
          return signedIn()
            && request.auth.uid == threadData().talentUid;
        }

        allow read: if isAdmin() || isAgreementParticipant();

        allow create: if isClient()
          && request.resource.data.status == "draft"
          && request.resource.data.terms is map
          && request.resource.data.updatedAt != null;

        allow update: if isAgreementParticipant()
          && request.resource.data.updatedAt != null;

        allow delete: if false;
      }
    }

    // ===== WALLETS =====
    match /wallets/{uid} {
      allow read: if isMe(uid) || isAdmin();
      allow write: if isMe(uid) || isAdmin();

      match /transactions/{txId} {
        allow read: if isMe(uid) || isAdmin();
        allow write: if false;
      }

      match /withdrawals/{withdrawalId} {
        allow read: if isMe(uid) || isAdmin();
        allow write: if false;
      }
    }

    // ===== REVIEWS =====
    match /reviews/{reviewId} {
      allow read: if isAdmin() || resource.data.isPublic == true
        || (
          signedIn()
          && (
            request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId
          )
        );

      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.workspaceId is string
        && request.resource.data.rating is number
        && request.resource.data.fromRole in ["client", "talent"]
        && request.resource.data.toRole in ["client", "talent"]
        && request.resource.data.isPublic is bool;

      allow update, delete: if false;
    }

    // ===== WORKSPACES =====
    match /workspaces/{workspaceId} {
      allow read: if isAdmin() || (
        signedIn()
        && (
          request.auth.uid == resource.data.clientUid
          || request.auth.uid == resource.data.talentUid
        )
      );

      allow create: if signedIn()
        && (
          request.auth.uid == request.resource.data.clientUid
          || request.auth.uid == request.resource.data.talentUid
        );

      allow update: if isAdmin() || (
        signedIn()
        && (
          request.auth.uid == resource.data.clientUid
          || request.auth.uid == resource.data.talentUid
        )
      );

      allow delete: if false;

      match /milestones/{milestoneId} {
        allow read: if isAdmin() || signedIn();
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /payoutRequests/{payoutId} {
        allow read: if isAdmin() || signedIn();
        allow create, update: if signedIn();
        allow delete: if false;
      }
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{notificationId} {
      allow read: if (signedIn() && resource.data.userId == request.auth.uid) || isAdmin();

      allow create: if false;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.read == true;

      allow delete: if false;
    }

    // ===== DISPUTES =====
    match /disputes/{disputeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== TRANSACTIONS =====
    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== DEFAULT =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
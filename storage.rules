rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPER FUNCTIONS =====
    function signedIn() {
      return request.auth != null;
    }

    function isDisputeParticipant(disputeId) {
      let dispute = firestore.get(/databases/(default)/documents/disputes/$(disputeId)).data;
      let ws = firestore.get(/databases/(default)/documents/workspaces/$(dispute.workspaceId)).data;
      return signedIn() && (
        request.auth.uid == ws.clientUid
        || request.auth.uid == ws.talentUid
      );
    }

    function isDisputeAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function wsExists(workspaceId) {
      return firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId));
    }

    function isWorkspaceParticipant(workspaceId) {
      return signedIn() && wsExists(workspaceId) && (
        request.auth.uid == firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)).data.clientUid
        || request.auth.uid == firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)).data.talentUid
      );
    }

    function isWorkspaceTalent(workspaceId) {
      return signedIn() && wsExists(workspaceId) &&
        request.auth.uid == firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)).data.talentUid;
    }

    function isFinalWorkApproved(workspaceId) {
      return firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/finalWork/submission)
        && firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/finalWork/submission).data.status == "approved";
    }

    function isMilestoneApproved(workspaceId, milestoneId) {
      return firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/milestones/$(milestoneId))
        && firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/milestones/$(milestoneId)).data.status == "approved";
    }

    function isGigOwnerOrNew(gigId) {
      return signedIn() && (
        !firestore.exists(/databases/(default)/documents/gigs/$(gigId))
        || request.auth.uid == firestore.get(/databases/(default)/documents/gigs/$(gigId)).data.clientUid
      );
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function threadExists(threadId) {
      return firestore.exists(/databases/(default)/documents/threads/$(threadId));
    }

    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && (request.auth.uid in firestore.get(/databases/(default)/documents/threads/$(threadId)).data.participants);
    }

    // ===== USER PROPOSALS =====
    match /users/{userId}/proposals/{proposalId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // === verification uploads (kyc/orgKyc) ===
    // the client-side components write into `users/{uid}/kyc` and
    // `users/{uid}/org-kyc`; allow the owning user to manage those files.
    match /users/{userId}/kyc/{allPaths=**} {
      // owner or admin may access verification files
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
    }
    match /users/{userId}/org-kyc/{allPaths=**} {
      allow read, write: if (signedIn() && request.auth.uid == userId) || isAdmin();
    }

    // ===== AGREEMENTS =====
   // ===== AGREEMENTS =====
    // Simplified: just check if signed in. Firestore rules validate thread participation.
    match /agreements/{threadId}/{fileName} {
      allow read, write: if signedIn();
    }

    // ===== THREAD MESSAGE ATTACHMENTS =====
    match /threads/{threadId}/attachments/{allPaths=**} {
      allow read, write: if isAdmin() || isThreadParticipant(threadId);
    }

    // ===== MILESTONES: RAW + PREVIEWS =====
    match /workspaces/{workspaceId}/milestones/{milestoneId}/raw/{allPaths=**} {
      allow write: if signedIn() && isWorkspaceTalent(workspaceId);
      allow read: if isAdmin()
        || isWorkspaceTalent(workspaceId)
        || (isWorkspaceParticipant(workspaceId) && isMilestoneApproved(workspaceId, milestoneId));
    }

    match /workspaces/{workspaceId}/milestones/{milestoneId}/previews {
      allow read: if signedIn();  // List folder
    }

    match /workspaces/{workspaceId}/milestones/{milestoneId}/previews/{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;  // Cloud Functions writes previews
    }

    // ===== HOURLY CHECKINS =====
    match /workspaces/{workspaceId}/hourly/checkins/{checkinId}/raw/{allPaths=**} {
      allow read, write: if signedIn() && isWorkspaceTalent(workspaceId);
    }

    match /workspaces/{workspaceId}/hourly/checkins/{checkinId}/previews {
      allow read: if signedIn();
    }

    match /workspaces/{workspaceId}/hourly/checkins/{checkinId}/previews/{allPaths=**} {
      allow read: if signedIn();
      allow write: if false;  // Cloud Functions writes previews
    }

    // ===== FINAL WORK =====
    match /workspaces/{workspaceId}/finalWork/raw/{allPaths=**} {
      allow read: if isAdmin()
        || isWorkspaceTalent(workspaceId)
        || (isWorkspaceParticipant(workspaceId) && isFinalWorkApproved(workspaceId));
      allow write: if signedIn() && isWorkspaceTalent(workspaceId);
    }

    match /workspaces/{workspaceId}/finalWork/previews/{allPaths=**} {
      allow read: if isWorkspaceParticipant(workspaceId);
      allow write: if false;  // Cloud Functions writes previews
      allow delete: if false;
    }

    // ===== GIGS =====
    match /gigs/{gigId}/attachments/{allPaths=**} {
      allow read, write: if isGigOwnerOrNew(gigId);
    }

    // ===== DISPUTES =====
    match /disputes/{disputeId}/evidence/{allPaths=**} {
      allow write: if isDisputeParticipant(disputeId) || isDisputeAdmin();
      allow read: if isDisputeParticipant(disputeId) || isDisputeAdmin();
    }

    // ===== DEFAULT DENY =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
